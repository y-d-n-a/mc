# OpenRouter API key - required for cloud model routing
OPENROUTER_API_KEY=


# OpenRouter base URL - defaults to https://openrouter.ai/api/v1 if not set
OPENROUTER_URL=


# Local cluster base URL - required when using ollama/ prefixed models
# This should point to an OpenAI-compatible /chat/completions endpoint
# Example: http://192.168.1.100:11434/v1  or  http://localhost:11434/v1
LOCAL_URL=


# Model for multicoder (mc get)
# Use provider/model-name for OpenRouter: anthropic/claude-sonnet-4.6
# Use ollama/model-name for local cluster: ollama/qwen3.5
AI_TOOLS_MODEL=


# Model for ask / askc
# Use provider/model-name for OpenRouter: anthropic/claude-sonnet-4.6
# Use ollama/model-name for local cluster: ollama/qwen3.5
ASK_APP_MODEL=


MAX_TOKENS=32768
TIMEOUT=600